              "});",
              "",
              "pm.test(\"Service is active\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"active\");",
              "});",
              "",
              "pm.test(\"Has all endpoints\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.endpoints).to.exist;",
              "    pm.expect(jsonData.endpoints.convert).to.exist;",
              "    pm.expect(jsonData.endpoints.single).to.exist;",
              "    pm.expect(jsonData.endpoints.discover).to.exist;",
              "    pm.expect(jsonData.endpoints.extract).to.exist;",
              "    pm.expect(jsonData.endpoints.diff).to.exist;",
              "    pm.expect(jsonData.endpoints.search).to.exist;",
              "    pm.expect(jsonData.endpoints.chunk).to.exist;",
              "    pm.expect(jsonData.endpoints['map-topics']).to.exist;",
              "    pm.expect(jsonData.endpoints.sitemap).to.exist;",
              "});"
