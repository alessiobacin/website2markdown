    {
      "name": "Convert Website - Example.com",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has success true\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "});",
              "",
              "pm.test(\"Response has domain\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.domain).to.exist;",
              "});",
              "",
              "pm.test(\"Response has pages array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.pages).to.be.an('array');",
              "    pm.expect(jsonData.totalPages).to.equal(jsonData.pages.length);",
              "});",
              "",
              "pm.test(\"Each page has required fields\", function () {",
              "    var jsonData = pm.response.json();",
              "    if (jsonData.pages.length > 0) {",
              "        var page = jsonData.pages[0];",
              "        pm.expect(page.url).to.exist;",
              "        pm.expect(page.title).to.exist;",
              "        pm.expect(page.markdown).to.exist;",
              "        pm.expect(page.wordCount).to.be.a('number');",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
