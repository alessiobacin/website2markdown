{
  "name": "website2markdown",
  "version": "1.0.0",
  "description": "API service + CLI to convert websites to markdown by discovering all pages through sitemap/robots.txt",
  "main": "dist/index.js",
  "bin": {
    "w2m": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli/index.js",
    "prepare": "tsc && chmod +x dist/cli/index.js",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "nodemon --exec ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "website",
    "markdown",
    "sitemap",
    "scraping",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.8.0",
    "@types/turndown": "^5.0.5",
    "@types/xml2js": "^0.4.14",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.0.0-rc.12",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "node-cron": "^4.6.0",
    "turndown": "^7.1.2",
    "typescript": "^5.2.2",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.1",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.1",
    "vitest": "^4.1.10"
  }
}
